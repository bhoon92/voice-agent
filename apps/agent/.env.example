# --- LiveKit (must match the server / docker --dev) ---
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# --- LLM / STT / TTS providers (free tiers, no card required) ---
# Groq: https://console.groq.com  (Llama LLM, Whisper STT, PlayAI TTS)
GROQ_API_KEY=
# Google AI Studio: https://aistudio.google.com/apikey  (Gemini LLM)
GOOGLE_API_KEY=
# ElevenLabs: https://elevenlabs.io  (Korean TTS, free 10k chars/month)
ELEVENLABS_API_KEY=

# --- Paid LLM providers (optional; enable Claude / GPT options) ---
# Anthropic: https://console.anthropic.com  (Claude Haiku 4.5)
ANTHROPIC_API_KEY=
# OpenAI: https://platform.openai.com  (GPT-4o)
OPENAI_API_KEY=

# --- Server (for transcript persistence) ---
SERVER_URL=http://localhost:4000
INTERNAL_API_SECRET=dev-internal-secret
